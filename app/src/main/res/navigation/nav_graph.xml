<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/fragListaDeCompras">

    <fragment
        android:id="@+id/addItem"
        android:name="dev.gmarques.compras.ui.add_item.FragAddItem"
        android:label="@string/novo_item"
        tools:layout="@layout/frag_add_item">

        <argument
            android:name="listaId"
            app:argType="string" />

    </fragment>


    <fragment
        android:id="@+id/editItem"
        android:name="dev.gmarques.compras.ui.edit_item.FragEditItem"
        tools:layout="@layout/frag_edit_item">

        <argument
            android:name="item"
            app:argType="dev.gmarques.compras.objetos.Item" />

    </fragment>

    <fragment
        android:id="@+id/fragListaDeCompras"
        android:name="dev.gmarques.compras.ui.lista_de_compras.FragListaDeCompras"
        android:label="@string/Compras"
        tools:layout="@layout/frag_lista_de_compras">


        <action
            android:id="@+id/action_fragListaDeCompras_to_addItem"
            app:destination="@id/addItem" />

    </fragment>

</navigation>