<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/fragListaDeCompras">

    <fragment
        android:id="@+id/addEditItem"
        android:name="dev.gmarques.compras.addEditItem.FragAddEditItem"
        android:label="@string/novo_item"
        tools:layout="@layout/fragment_add_edit_item" >
        <argument
            android:name="item"
            app:argType="dev.gmarques.compras.objetos.Item" />
    </fragment>
    <fragment
        android:id="@+id/fragListaDeCompras"
        android:name="dev.gmarques.compras.lista.FragListaDeCompras"
        android:label="@string/Compras"
        tools:layout="@layout/fragment_frag_lista_de_compras" >
        <action
            android:id="@+id/action_fragListaDeCompras_to_addEditItem"
            app:destination="@id/addEditItem" />
    </fragment>
</navigation>