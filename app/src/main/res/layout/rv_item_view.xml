<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="dev.gmarques.compras.objetos.Item" />

    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="3dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp">

            <TextView
                android:id="@+id/tvNome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:padding="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@{item.nome}"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/tv_preco_total"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Macarrão" />

            <TextView
                android:id="@+id/tv_preco_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:padding="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@{item.valotTotalEmMoeda()}"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="R$ 13,45" />

            <TextView
                android:id="@+id/tv_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:drawablePadding="4dp"
                android:ellipsize="marquee"
                android:fontFamily="@font/quicksand_medium"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp"
                android:text="@{item.detalhes}"
                app:drawableStartCompat="@drawable/vec_info_12"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/cbComprado"
                app:layout_constraintTop_toBottomOf="@id/tvNome"
                tools:text="teste de texto muito longo pra ver o que vai acontececr no final da linha" />

            <TextView
                android:id="@+id/tvQtd"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_margin="4dp"
                android:background="@drawable/retangulo_arredondado"
                android:drawablePadding="4dp"
                android:elevation="2dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="@{@string/un(item.qtd)}"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="?colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/vec_qtd_16"
                app:drawableTint="?colorPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tvPreco"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"
                tools:text="3un" />

            <TextView
                android:id="@+id/tvPreco"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_margin="4dp"
                android:background="@drawable/retangulo_arredondado"
                android:drawablePadding="4dp"
                android:elevation="2dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="@{item.emMoeda()}"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="?colorSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="normal"
                app:drawableStartCompat="@drawable/vec_money_16"
                app:drawableTint="?colorSecondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"
                tools:text="R$ 2,50" />


            <CheckBox
                android:id="@+id/cbComprado"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:checked="@={item.comprado}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_info"
                tools:ignore="TouchTargetSizeCheck" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>